# LEELA Studio Configuration Example
# Copy this file to .env and configure the variables

# Environment
ENV=development # development, staging, production
LOG_LEVEL=INFO

# API Keys
PIXVERSE_API_KEY=your_pixverse_key_here
ELEVENLABS_API_KEY=your_elevenlabs_key_here
SARVAM_API_KEY=your_sarvam_key_here

# Directory Settings
OUTPUT_DIR=output
CACHE_DIR=cache
LOGS_DIR=logs
ASSETS_DIR=assets
